# Copia in .env.local per lo sviluppo locale.
# Su Vercel: Project → Settings → Environment Variables (Production, Preview, Development).

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# OpenAI — solo server-side (Vercel: Environment Variables, non NEXT_PUBLIC_)
OPENAI_API_KEY=sk-your-openai-api-key
# Opzionale: default gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
